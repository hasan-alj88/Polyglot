{
  "packages": [
    {
      "registry": "Community",
      "path": ["DataHelpers"],
      "version": "2.3.1",
      "active": true,
      "pipelines": [
        {
          "name": "Transform",
          "inputs": [
            {
              "name": ".input",
              "type": "pg\\int",
              "required": true,
              "default": null
            },
            {
              "name": ".scale",
              "type": "pg\\int",
              "required": true,
              "default": "1"
            }
          ],
          "outputs": [
            {
              "name": ".result",
              "type": "pg\\int",
              "required": true,
              "default": null
            }
          ]
        },
        {
          "name": "ValidateString",
          "inputs": [
            {
              "name": ".text",
              "type": "pg\\string",
              "required": true,
              "default": null
            },
            {
              "name": ".min_length",
              "type": "pg\\int",
              "required": false,
              "default": "0"
            },
            {
              "name": ".max_length",
              "type": "pg\\int",
              "required": false,
              "default": "1000"
            }
          ],
          "outputs": [
            {
              "name": ".is_valid",
              "type": "pg\\bool",
              "required": true,
              "default": null
            }
          ]
        }
      ],
      "enumerations": [
        {
          "name": "Status",
          "fields": ["Active", "Inactive", "Pending"]
        },
        {
          "name": "ErrorLevel",
          "fields": ["Warning", "Error", "Fatal"]
        }
      ],
      "errors": [
        {
          "name": "ValidationError",
          "fields": ["message", "field"]
        },
        {
          "name": "ProcessingError",
          "fields": ["code", "description"]
        }
      ]
    },
    {
      "registry": "Local",
      "path": ["Utils"],
      "version": "1.0.0",
      "active": true,
      "pipelines": [
        {
          "name": "FormatDate",
          "inputs": [
            {
              "name": ".date",
              "type": "pg\\dt",
              "required": true,
              "default": null
            },
            {
              "name": ".format",
              "type": "pg\\string",
              "required": false,
              "default": "\"yyyy-MM-dd\""
            }
          ],
          "outputs": [
            {
              "name": ".formatted",
              "type": "pg\\string",
              "required": true,
              "default": null
            }
          ]
        }
      ],
      "enumerations": [],
      "errors": []
    },
    {
      "registry": "Enterprise",
      "path": ["Security", "Auth"],
      "version": "3.2.0",
      "active": true,
      "pipelines": [
        {
          "name": "ValidateToken",
          "inputs": [
            {
              "name": ".token",
              "type": "pg\\string",
              "required": true,
              "default": null
            }
          ],
          "outputs": [
            {
              "name": ".is_valid",
              "type": "pg\\bool",
              "required": true,
              "default": null
            },
            {
              "name": ".user_id",
              "type": "pg\\string",
              "required": true,
              "default": null
            }
          ]
        }
      ],
      "enumerations": [
        {
          "name": "AuthLevel",
          "fields": ["Guest", "User", "Admin", "SuperAdmin"]
        }
      ],
      "errors": [
        {
          "name": "AuthenticationError",
          "fields": ["message", "code", "details"]
        }
      ]
    }
  ]
}
