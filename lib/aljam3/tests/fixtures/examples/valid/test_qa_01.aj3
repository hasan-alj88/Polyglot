{@} @Local:55555<Score.Processing:1.1.0
   [@] @DB << @Company:TopHillHighSchool<StudentDB:1.3.5

{-} -File.CSV.Log
   [T] -T.CLI
   [Q] -Q.Default
   [W] -W.Aljam3
   [ ]
   [-] -T.Dummy
{-} -Agg.Flat.Max
   [T] -T.CLI
   [Q] -Q.Default
   [W] -W.Aljam3
   [ ]
   [-] -T.Dummy
{-} -Do.Nothing
   [T] -T.CLI
   [Q] -Q.Default
   [W] -W.Aljam3
   [ ]
   [-] -T.Dummy

{-} -ScoreProcessingPipeline
   [T] -T.Daily"5PM"
   [Q] -Q.Default
   [W] -W.Aljam3

   [ ]
   [-] @DB-Students.GetTestScores
      (-) $ScoresQuery
      (>) >status >> @DB#Status.Success
         (>) >! @DB#Status.Failed

   [?] ?ScoresQuery.Status.IsEqual"{#DB.Status.Failed}" =? #Boolean.True
      [-] -File.CSV.Log
         (<) <file.Path << "db_failed_{$today}.csv"
            (<) <! "db_failed_default.csv"
         [!] -Do.Nothing
   [?] *?
      [*] *Into.Array
         (*) << $ScoresQuery.data.math
         (*) << $ScoresQuery.data.science
         (*) >> $allScores#array.float.1D
         
      [-] -Agg.Flat.Max
         (<) <data << $allScores
         (>) >result >> $maxScore
         
      [?] ?Score.IsItGreaterThan"95.0" >? #Boolean.True
         [-] @Mail-API.Email.SendAlert
            (-) $EmailOperation
            (<) <recipient << "admin@acme.edu"
               (<) <! "backup@acme.edu"
            (<) <subject << "New high score!"
            (<) <message << "A student achieved {$maxScore}."
      [?] *?
         [-] -Do.Nothing
