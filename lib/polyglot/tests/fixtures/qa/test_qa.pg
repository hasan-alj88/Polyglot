{P} System.QA.Tests

{D} TestData
   [@] std/io
   [#] loadData > localData
   [?] localData == "value"
      [!] "Error condition met"
   [.] field access
   [:] flex field
   [&] and condition
   [|] or condition
   [^] xor condition
   [%] metadata "version 1.0"
   [C] foreign rust code
   [c] raw code block
   [b] background_task
   [~] continuation
   [#] var !< "fallback"
   [#] res !> "fallback_out"
   [#] (#)
      item1
      item2

{T} QA_Trigger
   (P) ^Pipeline1
   (I) > localData
   (I) !> localDataFallback
   (O) < result
   (O) !< resultFallback

{W} QA_Wrapper
   [@] std/http
   [b] wrap_service

{N} QA_Native
   [#] native_call > result

{Q} QA_Queue
   [#] queue_push > queue

{!} QA_Error
   [#] handle_error > log

{_} QA_Permission
   [#] check_auth > is_authed

{*} QA_Collector
   (C) < collection
   (O) < stream

{$} QA_Constructor
   [#] build_instance > instance

// Intentional Edge Cases and Invalid Syntax:
{X} InvalidDefinitionMarker
   [x] InvalidActionMarker
   [#] Missing arrow
   (X) Invalid IO marker
   [#] {nested} [markers]
