[ ] Lesson 001: Package Declarations
{@} @Company:AcmeCorp<Marketing.Campaigns:2.1.0
   [@] @CRM << @Company:AcmeCorp<Internal.CRM:1.0.0
   [@] @Mail << @Community:sendgrid<Mailer.Service:3.0.0

{-} -RunDailyCampaign
   [ ] Lesson 002: Pipeline Triggers
   [T] -T.Daily"8AM"
   [Q] -Q.HighPriority
   [ ]
   [ ] ERR: IO definitions must happen BEFORE triggers
   (-) <campaignDate#DT << $DT"today"
   [ ]
   [ ] Parallel fetch from two different CRM segments
   [=] @CRM-API.Users.GetSegment
      (-) <segment << "Active"
      (-) >users >> $activeUsers#array:string:1D
         [ ] Lesson 007: Output Fallbacks
         (>) >! $Array.String:1D"Empty"
   [ ]
   [=] @CRM-API.Users.GetSegment
      (-) <segment << "Churned"
      (-) >users >> $churnedUsers#array:string:1D
         (>) >! $Array.String:1D"Empty"
   [ ]
   [ ] Lesson 003: Parallel Collectors (Wait for both parallel fetches)
   [*] *All
      (*) << $activeUsers
      (*) << $churnedUsers
   [ ]
   [ ] Lesson 004: Array Dimension Initialization (explicit :2D on right side)
   [-] $allSegments#array:string:2D << #Array.String:2D
      (#) << $activeUsers
      (#) << $churnedUsers
   [ ]
   [ ] Lesson 005: String Interpolation
   [ ] ERR: Used <~ (mutable) instead of << (final assignment)
   [-] $emailSubject <~ "Daily Campaign Report for {<campaignDate}"
   [ ]
   [-] @Mail-API.Email.SendAdminReport
      [ ] ERR: Action not explicitly named, error handling wasn't idiomatic, missing typed outputs
      (-) <subject << $emailSubject
      (-) <data << $allSegments
      [ ] Lesson 006: Error Handling Blocks
      [!] *!
         [-] >status >> "FailedToSend"
   [ ]
   [-] >finalStatus >> "Success"
