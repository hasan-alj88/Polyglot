[ ]{@} @Science:Weather
[ ] declaration pakage are in the forms
[ ] @Local:Port<Package.Hierarchy:Version
[ ] @Community:username<Package.Hierarchy:Version
[ ] @Company:RegistredName<Package.Hierarchy:Version
{@} @Local:55555<QA:Test.ArraysAndPredicates:1.0.0
   [@] @Weather << @Community:coder123<Weather.Database:1.0.0
   [@] ;ClimateDB << @Weather;WeatherDB
   


{-} -CollectTemperatures
   [ ] If no Triggers the pipeline will never start 
   (-) <today#DT << $DT"today"
   (-) >file#Path 
   [T] -T.Daily"3AM"
   [Q] -Q.Default
   [W] -W.DB;ClimateDB
   [ ]
   [ ] Fetch 2D temperature matrices from different regions
   [ ]
   [=] @Weather-API.Sensor.GetRegion
      (-) <regionId << "North"
      (-) >matrix >> $northTemp#array:float:2D
         (>) >! $Array.Float:2D"Empty"
   [ ]
   [=] @Weather-API.Sensor.GetRegion
      (-) <regionId << "South"
      (-) >matrix >> $southTemp#array:float:2D
         (>) >! $Array.Float:2D"Empty"
   [ ]
   [ ] if the $southTemp and $northTemp are not collected
   [ ] from parallel execution its a compile Error
   [*] *All
      (*) << $northTemp
      (*) << $southTemp
   [ ] Combine 2D matrices into a 3D dataset using auto-incrementing append
   [-] $worldTemp#array:float:3D << #Array.Float:3D
      (#) << $northTemp
      (#) << $southTemp
   [ ]
   [ ] Direct scalar initialization for a threshold (0D Array)
   [-] $threshold#array:float:0D <~ $Array.Float"45.5"
   [ ]
   [ ] Save the dataset
   [-] $file <~ "~/Data/{<today}/worldTemp.csv"
   [-] -File.CSV.Write
      (-) <file << $file
      (-) <data << $worldTemp
      (-) <alertLevel << $threshold
      [!] *!
         [-] >file >> ""
   [-] >file >> $file 
