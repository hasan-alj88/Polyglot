{ } Basic Aljam3 Pipeline Example
{ } This demonstrates core syntax elements for testing highlighting
{@} @examples<syntax.test:1.0.0

{ } ============================================================================
{ } Pipeline with Input/Output
{ } ============================================================================
{-} -ProcessData
   [ ] Inputs
   (-) <input#string
   (-) <count#int <~ 10  // Default value
   [ ] Triggers and Constraints
   [T] -T.CLI
   [Q] -Q.Default
   [W] -W.Aljam3
   [ ]

   [ ] Sequential execution
   [-] $sanitized#string << <input
   [-] $length#int << $sanitized

   [ ] Conditional logic
   [?] $length >? 0
      [-] $valid#bool << #Boolean.True
   [?] *?
      [-] $valid#bool << #Boolean.False
   [ ]

   [ ] Parallel execution into a collector
   [*] *Into.Array
      (*) << $DT"2025-12-03T10:30:00Z"
      (*) << $sanitized
      (*) >> $parallelResults#array:string:1D
   [ ]

   { } Outputs
   (-) >sanitized#string >> $sanitized
   (-) >valid#bool >> $valid
   (-) >timestamp#datetime >> $DT"2025-12-03T10:30:00Z"

{ } ============================================================================
{ } Pipeline with Error Handling
{ } ============================================================================
{-} -SafeProcess
   (-) <data#string
   [T] -T.CLI
   [Q] -Q.Default
   [W] -W.Aljam3
   [ ]

   [-] -ProcessData
      (-) <input << <data
      (-) >sanitized >> $result#string
         (>) >! "default"  ( ) Error catch block fallback

   (-) >result#string >> $result 

{ } ============================================================================
{ } Error Definition
{ } ============================================================================
{!} !ValidationError
   [.] .message#string
   [.] .code#int
   [.] .trace#string

{!} !ProcessingError
   [.] .message#string
   [.] .code#int
   [.] .trace#string

{ } ============================================================================
{ } Enumeration Definition
{ } ============================================================================
{#} #Status
   [.] .Pending
   [.] .Processing
   [.] .Completed
   [.] .Failed

{ } ============================================================================
{ } Pipeline with Nested Scopes
{ } ============================================================================
{-} -NestedLogic
   (-) <value#int
   [T] -T.CLI
   [Q] -Q.Default
   [W] -W.Aljam3
   [ ]

   [ ] Nested scope for complex logic
   [?] <value >? 100
      [-] $category#string << "high"
   [?] (<value >=? 50) [&] (<value <=? 100)
      [-] $category#string << "medium"
   [?] <value <? 50
      [-] $category#string << "low"
   [?] *?
      [-] $category#string << "unknown"

   (-) >category#string >> $category

{ } ============================================================================
{ } Pipeline with DateTime Trigger
{ } ============================================================================
{-} -ScheduledTask
   [T] -T.Daily"09:00"
   [Q] -Q.Default
   [W] -W.Aljam3
   [ ]

   [-] $run_time#datetime << $DT"now"
   [-] $message#string << "Daily task executed"

   (-) >message#string >> $message

{ } ============================================================================
{ } Operators Showcase
{ } ============================================================================
{-} -OperatorsDemo
   (-) <a#int
   (-) <b#int
   [T] -T.CLI
   [Q] -Q.Default
   [W] -W.Aljam3
   [ ]

   [ ] Comparison operators
   [-] $equal#bool << (<a =? <b)
   [-] $greater#bool << (<a >? <b)
   [-] $less#bool << (<a <? <b)
   [-] $greater_eq#bool << (<a >=? <b)
   [-] $less_eq#bool << (<a <=? <b)
   [-] $not_equal#bool << (<a !? <b)

   [ ] Collection operators
   [-] ##Array.Int:1D
      (-) <item << 1
      (-) <item << 2
      (-) <item << 3
      (-) >array >> $list#array:int:1D

   [ ] Data flow operators
   [-] $push_value#int << 42       [ ] (<<) PUSH
   [-] $pull_value#int >> $a       [ ] (>>) PULL
   [-] $default_val#int <~ 100     [ ] (<~) DEFAULT (can override once)

   (-) >equal#bool >> $equal

{ } ============================================================================
{ } Multi-Language Type System
{ } ============================================================================
{-} -TypesShowcase
   (-) >array##Array
      (>) #<#int
      (>) #<Dim << 1
   [T] -T:CLI
   [Q] -Q:Default
   [W] -W:Aljam3
   [ ]

   [ ] Aljam3 native types
   [-] $pg_int#int << 42
   [-] $pg_float#float << 3.14
   [-] $pg_string#string << "hello"
   [-] $pg_bool#bool << #Boolean.True
   [-] $pg_path#path << "/tmp/file.txt"
   [=] @PakageAlias-Get.Url
      (-) >url >> $pg_url
         (>) >! "https://example.com"
   [=] @PakageAlias-Get.DateTime
      (-) >datetime >> $pg_datetime
         (>) >! $DT"Now"

   [*] *All
      (*) << $pg_url
      (*) << $pg_datetime

   [ ] Collection types
   [-] >array ##Array.String.1D >> $array_type
   [-] $map_type << #Map.String.Int

{ } ============================================================================
{ } Reserved Enumerations
{ } ============================================================================
{-} -ReservedEnums
   (-) <var_name#string
   [T] -T.CLI
   [Q] -Q.Default
   [W] -W.Aljam3
   [ ]

   [-] $bool_true#bool << #Boolean.True
   [-] $bool_false#bool << #Boolean.False
   [-] $none_value#string << #None

   [ ] Variable states (read-only)
   [-] $state_declared#string << #PgVar.States.Declared
   [-] $state_default#string << #PgVar.States.DefaultReady
   [-] $state_pending#string << #PgVar.States.Pending
   [-] $state_ready#string << #PgVar.States.Ready
   [-] $state_faulted#string << #PgVar.States.Faulted

{ } ============================================================================
{ } Line Continuation & Metadata
{ } ============================================================================
{-} -LineContinuation
   (-) <long_input#string
   [T] -T.CLI
   [Q] -Q.Default
   [W] -W.Aljam3
   [ ]

   [ ] Metadata
   [%] .description << "Testing continuations"

   [ ] Long expression using line continuation marker [~] or (~)
   [-] $complex_result#string << "prefix"
      [~] << <long_input
      [~] << "suffix"
      [~] << "more"

   (-) >complex_result#string >> $complex_result

{ } ============================================================================
{ } Native Function & Extensibility System
{ } ============================================================================
{-} =T.LogMessage
   [=] <message#string
   [=] >timestamp#datetime
   [=] >log_entry#string
   [=] >IsTriggered#bool

{-} -UseMacro
   (-) <msg#string
   [T] -T.CLI
   [Q] -Q.Default
   [W] -W.Aljam3
   [ ]

   [ ] Custom native call
   [=] =T.LogMessage
      (=) <message << <msg
      (=) >log_entry >> $log_entry#string

   (-) >log_entry#string >> $log_entry
