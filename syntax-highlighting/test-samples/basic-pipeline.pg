// Basic Polyglot Pipeline Example
// This demonstrates core syntax elements for testing highlighting

[@] @examples/syntax-test

// ============================================================================
// Pipeline with Input/Output
// ============================================================================
[|] |ProcessData
  [i] .input: pg\string
  [i] .count: pg\int <~ 10  // Default value
  [t] |T.Manual

  // Sequential execution
  [r] .sanitized: pg\string << .input
  [r] .length: pg\int << .sanitized

  // Conditional logic
  [?] .length >? 0
    [r] .valid: pg\bool << #Boolean.True
  [X]
  [?] !(.length >? 0)
    [r] .valid: pg\bool << #Boolean.False
  [X]

  // Parallel execution
  [p] .timestamp: pg\datetime << DT"2025-12-03T10:30:00Z"
  [p] .hash: pg\string << .sanitized

  [o] .sanitized: pg\string
  [o] .valid: pg\bool
  [o] .timestamp: pg\datetime
[X]

// ============================================================================
// Pipeline with Error Handling
// ============================================================================
[|] |SafeProcess
  [i] .data: pg\string
  [t] |T.Manual

  [r] .result: pg\string << .data

  // Error catch block
  [~][!] !ValidationError
    [r] .fallback: pg\string << "default"
    [r] .result << .fallback
  [X]

  [o] .result: pg\string
[X]

// ============================================================================
// Error Definition
// ============================================================================
[!] !ValidationError
  .message: pg\string
  .code: pg\int
  .trace: pg\string
[X]

[!] !ProcessingError
  .message: pg\string
  .code: pg\int
  .trace: pg\string
[X]

// ============================================================================
// Enumeration Definition
// ============================================================================
[#] #Status
  .Pending
  .Processing
  .Completed
  .Failed
[X]

// ============================================================================
// Pipeline with Join Point (Collection Processing)
// ============================================================================
[|] |ProcessBatch
  [i] .items: pg\array{pg\string}
  [t] |T.Manual

  // Join point - process each item in parallel
  [Y] ~.items
    [p] .processed: pg\string << .items
  [X]

  // Pack results back into collection
  [r] .results: pg\array{pg\string} << ~Y.*

  [o] .results: pg\array{pg\string}
[X]

// ============================================================================
// Pipeline with Runtime Wrapper
// ============================================================================
[|] |PythonIntegration
  [i] .script_path: pg\path
  [i] .function_name: pg\string
  [i] .args: pg\array{pg\string}
  [t] |T.Manual

  [W] RT.Python
    .script: pg\path << .script_path
    .function: pg\string << .function_name
    .arguments: pg\array{pg\string} << .args
  [X]

  [r] .result: py\dict << .args  // Python dict type

  [o] .result: py\dict
[X]

// ============================================================================
// Pipeline with Nested Scopes
// ============================================================================
[|] |NestedLogic
  [i] .value: pg\int
  [t] |T.Manual

  [r] .category: pg\string

  // Nested scope for complex logic
  [~]
    [ ]
    [?] .value >? 100
      [r] .category << "high"
    [X]
    [?] (.value >=? 50) [&] (.value <=? 100)
      [r] .category << "medium"
    [X]
    [?] .value <? 50
      [r] .category << "low"
    [X]
  [X]

  [o] .category: pg\string
[X]

// ============================================================================
// Pipeline with DateTime Trigger
// ============================================================================
[|] |ScheduledTask
  [i] !No.Input
  [t] |T.DT.Daily
    .time: pg\string << "09:00"
  [X]

  [r] .run_time: pg\datetime << DT"now"
  [r] .message: pg\string << "Daily task executed"

  [o] .message: pg\string
[X]

// ============================================================================
// Operators Showcase
// ============================================================================
[|] |OperatorsDemo
  [i] .a: pg\int
  [i] .b: pg\int
  [t] |T.Manual

  // Comparison operators
  [r] .equal: pg\bool << (.a =? .b)
  [r] .greater: pg\bool << (.a >? .b)
  [r] .less: pg\bool << (.a <? .b)
  [r] .greater_eq: pg\bool << (.a >=? .b)
  [r] .less_eq: pg\bool << (.a <=? .b)
  [r] .not_equal: pg\bool << (.a !? .b)

  // Range operators
  [r] .in_range_closed: pg\bool << .a ?[10, 20]      // [10, 20]
  [r] .in_range_half_open: pg\bool << .a ?[10, 20)   // [10, 20)
  [r] .in_range_half_open2: pg\bool << .a ?(10, 20]  // (10, 20]
  [r] .in_range_open: pg\bool << .a ?(10, 20)        // (10, 20)

  // Collection operators
  [r] .list: pg\array{pg\int} << [1, 2, 3]
  [r] .unpacked: pg\int << ~*.list              // Unpack
  [r] .map: pg\map{pg\string, pg\int} << {"a": 1, "b": 2}

  // Data flow operators
  [r] .push_value: pg\int << 42       // << PUSH
  [r] .pull_value: pg\int >> .a       // >> PULL
  [r] .default_val: pg\int <~ 100     // <~ DEFAULT (can override once)

  [o] .equal: pg\bool
  [o] !No.Output
[X]

// ============================================================================
// Multi-Language Type System
// ============================================================================
[|] |TypesShowcase
  [i] !No.Input
  [t] |T.Manual

  // Polyglot native types
  [r] .pg_int: pg\int << 42
  [r] .pg_float: pg\float << 3.14
  [r] .pg_string: pg\string << "hello"
  [r] .pg_bool: pg\bool << #Boolean.True
  [r] .pg_path: pg\path << "/tmp/file.txt"
  [r] .pg_url: pg\url << "https://example.com"
  [r] .pg_datetime: pg\datetime << DT"2025-12-03T00:00:00Z"

  // Rust types
  [r] .rs_vec: rs\Vec{i32} << [1, 2, 3]
  [r] .rs_option: rs\Option{String} << "value"

  // Python types
  [r] .py_list: py\list << [1, 2, 3]
  [r] .py_dict: py\dict << {"key": "value"}

  // JavaScript types
  [r] .js_array: js\Array << [1, 2, 3]
  [r] .js_object: js\Object << {"key": "value"}

  // Go types
  [r] .go_slice: go\[]int << [1, 2, 3]
  [r] .go_map: go\map[string]int << {"a": 1}

  // Collection types
  [r] .array_type: pg\array{pg\int} << [1, 2, 3]
  [r] .map_type: pg\map{pg\string, pg\int} << {"a": 1}
  [r] .set_type: pg\set{pg\string} << {"a", "b", "c"}

  [o] !No.Output
[X]

// ============================================================================
// Reserved Enumerations
// ============================================================================
[|] |ReservedEnums
  [i] .var_name: pg\string
  [t] |T.Manual

  [r] .bool_true: pg\bool << #Boolean.True
  [r] .bool_false: pg\bool << #Boolean.False
  [r] .none_value: pg\string << #None

  // Variable states (read-only)
  [r] .state_declared: pg\string << #PgVar.States.Declared
  [r] .state_default: pg\string << #PgVar.States.DefaultReady
  [r] .state_pending: pg\string << #PgVar.States.Pending
  [r] .state_ready: pg\string << #PgVar.States.Ready
  [r] .state_faulted: pg\string << #PgVar.States.Faulted

  [o] !No.Output
[X]

// ============================================================================
// Line Continuation
// ============================================================================
[|] |LineContinuation
  [i] .long_input: pg\string
  [t] |T.Manual

  // Long expression using line continuation marker [*]
  [r] .complex_result: pg\string << [*]
    .long_input [*]
    << "suffix" [*]
    << "more"

  [o] .complex_result: pg\string
[X]

// ============================================================================
// Macro System
// ============================================================================
[M] ~LogMessage
  [i] .message: pg\string

  [r] .timestamp: pg\datetime << DT"now"
  [r] .log_entry: pg\string << .timestamp << .message

  [o] .log_entry: pg\string
[X]

[|] |UseMacro
  [i] .msg: pg\string
  [t] |T.Manual

  // Macro injection
  [{] ~LogMessage
    .message << .msg
  [}]

  [o] .log_entry: pg\string
[X]
