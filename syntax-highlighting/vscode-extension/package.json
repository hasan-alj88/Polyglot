{
  "name": "aljam3-language-support",
  "displayName": "Aljam3 Language Support",
  "description": "Syntax highlighting and language support for Aljam3 automation language",
  "version": "0.1.13",
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:aljam3"
  ],
  "publisher": "aljam3-lang",
  "icon": "icons/extension-icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "aljam3",
    "automation",
    "pipeline",
    "workflow",
    "orchestration"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aljam3-lang/aljam3"
  },
  "contributes": {
    "languages": [
      {
        "id": "aljam3",
        "aliases": [
          "Aljam3",
          "aljam3"
        ],
        "extensions": [
          ".jm3"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/icon-light.png",
          "dark": "./icons/icon-dark.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "aljam3",
        "scopeName": "source.aljam3",
        "path": "./syntaxes/aljam3.tmLanguage.json"
      },
      {
        "scopeName": "markdown.aljam3.codeblock",
        "path": "./syntaxes/aljam3.markdown.injection.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.aljam3": "aljam3"
        }
      }
    ],
    "snippets": [
      {
        "language": "aljam3",
        "path": "./snippets/aljam3.json"
      }
    ],
    "themes": [
      {
        "label": "Aljam3 Semantic Theme",
        "uiTheme": "vs-dark",
        "path": "./themes/aljam3-debug-color-theme.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@types/node": "^16.11.0",
    "typescript": "^4.9.5",
    "@vscode/vsce": "^2.19.0"
  },
  "dependencies": {
    "oniguruma": "^7.2.3",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  }
}
