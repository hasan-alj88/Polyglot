{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Aljam3",
  "scopeName": "source.aljam3",
  "fileTypes": [".jm3"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#inline-strings" },
    { "include": "#numbers" },
    { "include": "#triggers" },
    { "include": "#queues" },
    { "include": "#wrappers" },
    { "include": "#pipelines" },
    { "include": "#parallels" },
    { "include": "#backgrounds" },
    { "include": "#environments" },
    { "include": "#variables" },
    { "include": "#packages" },
    { "include": "#io-tags" },
    { "include": "#datatypes-schema" },
    { "include": "#properties" },
    { "include": "#constants" },
    { "include": "#metadata" },
    { "include": "#exceptions-errors" },
    { "include": "#logical-nodes" },
    { "include": "#collectors" },
    { "include": "#assignment-operators" },
    { "include": "#permissions" }
  ],
  "repository": {
    "pipelines": {
      "patterns": [
        { "name": "entity.name.function.pipeline.aljam3", "match": "\\[-\\]|\\{-\\}|\\(-\\)" },
        { "name": "entity.name.function.pipeline.aljam3", "match": "\\-[A-Za-z0-9_]+" }
      ]
    },
    "parallels": {
      "patterns": [
        { "name": "entity.name.function.parallel.aljam3", "match": "\\[=\\]|\\{=\\}|\\(=\\)" },
        { "name": "entity.name.function.parallel.aljam3", "match": "\\=[A-Za-z0-9_]+" }
      ]
    },
    "backgrounds": {
      "patterns": [
        { "name": "entity.name.function.background.aljam3", "match": "\\[b\\]|\\{b\\}|\\(b\\)" },
        { "name": "entity.name.function.background.aljam3", "match": "\\-b[\\.:][A-Za-z0-9_]+" }
      ]
    },
    "triggers": {
      "patterns": [
        { "name": "entity.name.type.trigger.aljam3", "match": "\\[T\\]|\\{T\\}|\\(T\\)" },
        { "name": "entity.name.type.trigger.aljam3", "match": "\\-T[\\.:][A-Za-z0-9_]+" }
      ]
    },
    "queues": {
      "patterns": [
        { "name": "entity.name.type.queue.aljam3", "match": "\\[Q\\]|\\{Q\\}|\\(Q\\)" },
        { "name": "entity.name.type.queue.aljam3", "match": "\\-Q[\\.:][A-Za-z0-9_]+" }
      ]
    },
    "wrappers": {
      "patterns": [
        { "name": "entity.name.type.wrapper.aljam3", "match": "\\[W\\]|\\{W\\}|\\(W\\)" },
        { "name": "entity.name.type.wrapper.aljam3", "match": "\\-W[\\.:][A-Za-z0-9_]+" }
      ]
    },
    "environments": {
      "patterns": [
        { "name": "entity.name.environment.aljam3", "match": "\\{;\\}|\\[;\\]|\\(;\\)" },
        { "name": "entity.name.environment.aljam3", "match": ";[A-Za-z0-9_]+" }
      ]
    },
    "variables": {
      "patterns": [
        { "name": "variable.name.aljam3", "match": "\\[\\$\\]|\\{\\$\\}|\\(\\$\\)" },
        { "name": "variable.name.aljam3", "match": "\\$[A-Za-z0-9_]+|\\$\\*" }
      ]
    },
    "packages": {
      "patterns": [
        { "name": "entity.name.namespace.aljam3", "match": "\\[@\\]|\\{@\\}|\\(@\\)" },
        { "name": "entity.name.namespace.aljam3", "match": "@[A-Za-z0-9_]+" }
      ]
    },
    "io-tags": {
      "patterns": [
        { "name": "entity.name.tag.io.aljam3", "match": "\\(>\\)|\\(<\\)|\\(\\$\\)" },
        { "name": "entity.name.tag.schema.aljam3", "match": "#<[A-Za-z0-9_]+" },
        { "name": "entity.name.tag.input.aljam3", "match": "<[A-Za-z0-9_]+" },
        { "name": "entity.name.tag.output.aljam3", "match": ">[A-Za-z0-9_]+" }
      ]
    },
    "datatypes-schema": {
      "patterns": [
        { "name": "entity.name.type.aljam3", "match": "\\[##\\]|\\{##\\}|\\(##\\)|\\[#\\]|\\{#\\}|\\(#\\)" },
        { "name": "entity.name.type.aljam3", "match": "###[A-Za-z0-9_]+|##[A-Za-z0-9_]+|#[A-Za-z0-9_]+" }
      ]
    },
    "properties": {
      "patterns": [
        { "name": "variable.name.property.aljam3", "match": "\\[\\.\\]|\\(\\.\\)|\\[:\\]|\\(:\\)" },
        { "name": "variable.name.property.aljam3", "match": "[\\.:][A-Za-z0-9_]+" }
      ]
    },
    "constants": {
      "patterns": [
        { "name": "constant.language.aljam3", "match": "%[A-Za-z0-9_]+" }
      ]
    },
    "metadata": {
      "patterns": [
        { "name": "entity.name.tag.metadata.aljam3", "match": "\\[%\\]|\\{%\\}|\\(%\\)" },
        { "name": "entity.name.tag.metadata.aljam3", "match": "<%|>%" }
      ]
    },
    "exceptions-errors": {
      "patterns": [
        { "name": "invalid.illegal.aljam3", "match": "\\[!\\]|\\{!\\}|<!|>!|\\*!" },
        { "name": "invalid.illegal.aljam3", "match": "![A-Za-z0-9_]+" }
      ]
    },
    "logical-nodes": {
      "patterns": [
        { "name": "keyword.operator.logical.aljam3", "match": "\\[\\?\\]|\\[\\+\\]|\\[&\\]|\\[\\^\\]" },
        { "name": "keyword.operator.logical.aljam3", "match": ">\\?|<\\?|<=\\?|>=\\?|!\\?|=\\?|\\*\\?" },
        { "name": "keyword.operator.logical.aljam3", "match": "\\?[A-Za-z0-9_]+" }
      ]
    },
    "collectors": {
      "patterns": [
        { "name": "entity.name.collector.aljam3", "match": "\\[\\*\\]|\\{\\*\\}|\\(\\*\\)" },
        { "name": "entity.name.collector.aljam3", "match": "\\*[A-Za-z0-9_]+" }
      ]
    },
    "assignment-operators": {
      "patterns": [
        { "name": "keyword.operator.assignment.aljam3", "match": "<<|<~|<-|>>" }
      ]
    },
    "permissions": {
      "patterns": [
        { "name": "constant.other.permission.aljam3", "match": "\\[_\\]|\\{_\\}|\\(_\\)" },
        { "name": "constant.other.permission.aljam3", "match": "_[A-Za-z0-9_]+" }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.bracket.aljam3",
          "match": "(\\{\\s*\\}|\\[\\s*\\]|\\(\\s*\\)).*$"
        },
        {
          "name": "comment.line.double-slash.aljam3",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.aljam3",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.aljam3",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "inline-strings": {
      "patterns": [
        {
          "match": "([\\$\\-#_!%@<>;\\*\\?]\\!?(?:[A-Za-z0-9_]+|\\$))(\"[^\"]*\")",
          "captures": {
            "1": { "name": "variable.name.aljam3" },
            "2": { "name": "string.interpolated.aljam3" }
          }
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.aljam3",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.aljam3",
          "match": "\\b\\d+\\b"
        }
      ]
    }
  }
}
