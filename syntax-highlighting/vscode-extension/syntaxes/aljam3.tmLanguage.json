{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Aljam3",
  "scopeName": "source.aljam3",
  "fileTypes": [".jm3"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#markers" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.aljam3",
          "match": "^\\s*(\\{\\s*\\}|\\[\\s*\\]|\\(\\s*\\)|//).*$"
        },
        {
          "name": "comment.line.inline.aljam3",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.aljam3",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.aljam3",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.aljam3",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.aljam3",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "entity.name.tag.input.aljam3",
          "match": "<<|<~|<"
        },
        {
          "name": "entity.name.tag.output.aljam3",
          "match": ">>|~>|>"
        }
      ]
    },
    "markers": {
      "patterns": [
        { "name": "entity.name.tag.trigger.aljam3", "match": "\\[T\\]|\\{T\\}|\\(T\\)" },
        { "name": "entity.name.tag.execution.aljam3", "match": "\\[-\\]|\\{-\\}|\\(-\\)|\\[b\\]|\\{b\\}|\\(b\\)" },
        { "name": "entity.name.tag.parallel.aljam3", "match": "\\[=\\]|\\{=\\}|\\(=\\)" },
        { "name": "entity.name.tag.wrapper.aljam3", "match": "\\[W\\]|\\{W\\}|\\(W\\)|\\[\\\\\\]|\\[/\\]" },
        { "name": "entity.name.tag.environment.aljam3", "match": "\\[;\\]|\\{;\\}|\\(;\\)" },
        { "name": "entity.name.tag.queue.aljam3", "match": "\\[Q\\]|\\{Q\\}|\\(Q\\)" },
        { "name": "entity.name.tag.collector.aljam3", "match": "\\[\\*\\]|\\{\\*\\}|\\(\\*\\)" },
        { "name": "entity.name.tag.error.aljam3", "match": "\\[!\\]|\\{!\\}|\\(!\\)" },
        { "name": "entity.name.tag.permission.aljam3", "match": "\\[_\\]|\\{_\\}|\\(_\\)" },
        { "name": "entity.name.tag.conditional.aljam3", "match": "\\[\\?\\]|\\{\\?\\}|\\(\\?\\)" },
        { "name": "entity.name.tag.package.aljam3", "match": "\\[@\\]|\\{@\\}|\\(@\\)" },
        { "name": "entity.name.tag.metadata.aljam3", "match": "\\[%\\]|\\{%\\}|\\(%\\)" },
        { "name": "entity.name.tag.type.aljam3", "match": "\\[##\\]|\\{##\\}|\\(##\\)|\\[#\\]|\\{#\\}|\\(#\\)" },
        { "name": "entity.name.tag.instance.aljam3", "match": "\\[\\$\\]|\\{\\$\\}|\\(\\$\\)" },
        { "name": "entity.name.tag.input.aljam3", "match": "\\[<\\]|\\{<\\}|\\(<\\)" },
        { "name": "entity.name.tag.output.aljam3", "match": "\\[>\\]|\\{>\\}|\\(>\\)" },
        { "name": "entity.name.tag.subfield.aljam3", "match": "\\[\\.\\]|\\{\\.\\}|\\(\\.\\)|\\[:\\]|\\{:\\}|\\(:\\)" }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "match": "(-T\\.)([A-Za-z0-9_]+)?",
          "captures": { "1": { "name": "entity.name.tag.trigger.aljam3" } }
        },
        {
          "match": "(-Q\\.)([A-Za-z0-9_]+)?",
          "captures": { "1": { "name": "entity.name.tag.queue.aljam3" } }
        },
        {
          "match": "(-W\\.)([A-Za-z0-9_]+)?",
          "captures": { "1": { "name": "entity.name.tag.wrapper.aljam3" } }
        },
        {
          "match": "(-)([A-Za-z0-9_]+)?",
          "captures": { "1": { "name": "entity.name.tag.execution.aljam3" } }
        },
        {
          "match": "(=\\*)([A-Za-z0-9_]+)?",
          "captures": { "1": { "name": "entity.name.tag.reassembler.aljam3" } }
        },
        {
          "match": "(=)([A-Za-z0-9_]+)?",
          "captures": { "1": { "name": "entity.name.tag.parallel.aljam3" } }
        },
        {
          "match": "(\\*)([A-Za-z0-9_]+)?",
          "captures": { "1": { "name": "entity.name.tag.collector.aljam3" } }
        },
        {
          "match": "(@)([A-Za-z0-9_]+)?",
          "captures": { "1": { "name": "entity.name.tag.package.aljam3" } }
        },
        {
          "match": "(%)([A-Za-z0-9_]+)?",
          "captures": { "1": { "name": "entity.name.tag.metadata.aljam3" } }
        },
        {
          "match": "(;)([A-Za-z0-9_]+)?",
          "captures": { "1": { "name": "entity.name.tag.environment.aljam3" } }
        },
        {
          "match": "(___|__|_)([A-Za-z0-9_]+)?",
          "captures": { "1": { "name": "entity.name.tag.permission.aljam3" } }
        },
        {
          "match": "(!)([A-Za-z0-9_]+)?",
          "captures": { "1": { "name": "entity.name.tag.error.aljam3" } }
        },
        {
          "match": "(\\?)([A-Za-z0-9_]+)?",
          "captures": { "1": { "name": "entity.name.tag.conditional.aljam3" } }
        },
        {
          "match": "(###|##|#)([A-Za-z0-9_]+)?",
          "captures": { "1": { "name": "entity.name.tag.type.aljam3" } }
        },
        {
          "match": "(\\$\\$|\\$)([A-Za-z0-9_]+)?",
          "captures": { "1": { "name": "entity.name.tag.instance.aljam3" } }
        },
        {
          "match": "(\\.|:)([A-Za-z0-9_]+)?",
          "captures": { "1": { "name": "entity.name.tag.subfield.aljam3" } }
        }
      ]
    }
  }
}
