{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Polyglot",
  "scopeName": "source.polyglot",
  "fileTypes": [".pg"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#block-markers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#identifiers"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#datetime-strings"
    },
    {
      "include": "#types"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#error-markers"
    },
    {
      "include": "#reserved-enums"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.polyglot",
          "match": "//.*$"
        }
      ]
    },
    "block-markers": {
      "patterns": [
        {
          "name": "keyword.control.registry.polyglot",
          "match": "\\[@\\]|\\[\\|\\]|\\[#\\]|\\[!\\]|\\[M\\]"
        },
        {
          "name": "keyword.control.dataflow.polyglot",
          "match": "\\[i\\]|\\[o\\]|\\[<\\]|\\[>\\]"
        },
        {
          "name": "keyword.control.execution.polyglot",
          "match": "\\[r\\]|\\[p\\]|\\[b\\]|\\[s\\]|\\[Y\\]"
        },
        {
          "name": "keyword.control.flow.polyglot",
          "match": "\\[\\?\\]|\\[t\\]|\\[Q\\]|\\[W\\]"
        },
        {
          "name": "keyword.control.scope.polyglot",
          "match": "\\[~\\]|\\[\\\\\\]|\\[/\\]|\\[\\{\\]|\\[\\}\\]"
        },
        {
          "name": "keyword.operator.logical.polyglot",
          "match": "\\[&\\]|\\[\\+\\]|\\[-\\]|\\[\\^\\]|\\[\\.\\]"
        },
        {
          "name": "keyword.control.special.polyglot",
          "match": "\\[X\\]|\\[A\\]|\\[\\*\\]"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.dataflow.push.polyglot",
          "match": "<<"
        },
        {
          "name": "keyword.operator.dataflow.pull.polyglot",
          "match": ">>"
        },
        {
          "name": "keyword.operator.dataflow.default.polyglot",
          "match": "<~"
        },
        {
          "name": "keyword.operator.comparison.polyglot",
          "match": "=\\?|>\\?|<\\?|>=\\?|<=\\?|!\\?"
        },
        {
          "name": "keyword.operator.range.polyglot",
          "match": "\\?\\[|\\?\\("
        },
        {
          "name": "keyword.operator.collection.polyglot",
          "match": "~\\*|~[A-Z][a-zA-Z0-9]*\\.\\*"
        },
        {
          "name": "keyword.operator.assignment.polyglot",
          "match": ":"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.function.pipeline.polyglot",
          "match": "\\|[A-Z][a-zA-Z0-9_.]*"
        },
        {
          "name": "entity.name.type.enumeration.polyglot",
          "match": "#[A-Z][a-zA-Z0-9_.]*"
        },
        {
          "name": "entity.name.type.error.polyglot",
          "match": "![A-Z][a-zA-Z0-9_.]*"
        },
        {
          "name": "variable.other.polyglot",
          "match": "\\.[a-z][a-zA-Z0-9_]*"
        },
        {
          "name": "entity.name.package.polyglot",
          "match": "@[a-z][a-zA-Z0-9_./-]*"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.polyglot",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.polyglot",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "datetime-strings": {
      "patterns": [
        {
          "name": "string.quoted.datetime.polyglot",
          "begin": "DT\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.polyglot",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.namespace.polyglot",
          "match": "\\b(pg|rs|py|js|go)\\\\"
        },
        {
          "name": "storage.type.primitive.polyglot",
          "match": "\\b(int|float|string|bool|path|url|datetime)\\b"
        },
        {
          "name": "storage.type.collection.polyglot",
          "match": "\\b(array|map|set)\\b"
        },
        {
          "name": "storage.type.wrapper.polyglot",
          "match": "\\bRT\\.(Python|Rust|Node|Go)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.polyglot",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.polyglot",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "error-markers": {
      "patterns": [
        {
          "name": "constant.language.error.polyglot",
          "match": "!No\\.(Input|Output)"
        }
      ]
    },
    "reserved-enums": {
      "patterns": [
        {
          "name": "constant.language.boolean.polyglot",
          "match": "#Boolean\\.(True|False)"
        },
        {
          "name": "constant.language.none.polyglot",
          "match": "#None"
        },
        {
          "name": "constant.language.state.polyglot",
          "match": "#PgVar\\.States\\.(Declared|DefaultReady|Pending|Ready|Faulted)"
        }
      ]
    }
  }
}
