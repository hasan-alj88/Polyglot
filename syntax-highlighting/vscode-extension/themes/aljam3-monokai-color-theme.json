{
  "name": "Aljam3 Monokai",
  "type": "dark",
  "colors": {
    "editor.background": "#272822",
    "editor.foreground": "#f8f8f2",
    "editor.selectionBackground": "#49483e",
    "editor.lineHighlightBackground": "#3e3d32",
    "editorCursor.foreground": "#f8f8f0",
    "editorWhitespace.foreground": "#464741"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": "comment.line.aljam3",
      "settings": {
        "foreground": "#75715e"
      }
    },
    {
      "name": "Pipelines",
      "scope": "entity.name.function.pipeline.aljam3",
      "settings": {
        "foreground": "#a6e22e"
      }
    },
    {
      "name": "Parallels",
      "scope": "entity.name.function.parallel.aljam3",
      "settings": {
        "foreground": "#fd971f"
      }
    },
    {
      "name": "Variables",
      "scope": "variable.other.aljam3",
      "settings": {
        "foreground": "#f8f8f2"
      }
    },
    {
      "name": "DataType",
      "scope": "entity.name.type.aljam3",
      "settings": {
        "foreground": "#66d9ef"
      }
    },
    {
      "name": "Schema and Terminals",
      "scope": "support.type.aljam3",
      "settings": {
        "foreground": "#66d9ef",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Packages",
      "scope": "entity.name.namespace.aljam3",
      "settings": {
        "foreground": "#fd971f"
      }
    },
    {
      "name": "Errors",
      "scope": "keyword.control.exception.aljam3",
      "settings": {
        "foreground": "#f92672"
      }
    },
    {
      "name": "Permissions",
      "scope": "support.class.aljam3",
      "settings": {
        "foreground": "#66d9ef"
      }
    },
    {
      "name": "Metadata",
      "scope": "variable.language.special.aljam3",
      "settings": {
        "foreground": "#ae81ff"
      }
    },
    {
      "name": "Expanders and Assignment",
      "scope": "keyword.operator.assignment.aljam3",
      "settings": {
        "foreground": "#f92672"
      }
    },
    {
      "name": "Predicates",
      "scope": "keyword.operator.logical.aljam3",
      "settings": {
        "foreground": "#f92672"
      }
    },
    {
      "name": "Collections",
      "scope": "keyword.control.loop.aljam3",
      "settings": {
        "foreground": "#f92672"
      }
    },
    {
      "name": "Strings",
      "scope": "string.quoted.double.aljam3",
      "settings": {
        "foreground": "#E6DB74"
      }
    },
    {
      "name": "IO Tags",
      "scope": "entity.name.tag.io.aljam3",
      "settings": {
        "foreground": "#F92672"
      }
    },
    {
      "name": "Inline Strings",
      "scope": "string.interpolated.aljam3",
      "settings": {
        "foreground": "#A6E22E"
      }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric.float.aljam3", "constant.numeric.integer.aljam3"],
      "settings": {
        "foreground": "#AE81FF"
      }
    },
    {
      "name": "Separators, Brackets, and Accessors",
      "scope": ["punctuation.separator.aljam3", "punctuation.definition.bracket.aljam3", "keyword.operator.accessor.aljam3"],
      "settings": {
        "foreground": "#F8F8F2"
      }
    }
  ]
}
