    { "name": "Trigger (Wait)", "scope": "entity.name.tag.trigger.aljam3", "settings": { "foreground": "#FFD700", "fontStyle": "bold" } },
    { "name": "Queue (Wait)", "scope": "entity.name.tag.queue.aljam3", "settings": { "foreground": "#F0E68C", "fontStyle": "bold" } },
    { "name": "Collector (Wait)", "scope": "entity.name.tag.collector.aljam3", "settings": { "foreground": "#EEE8AA", "fontStyle": "bold" } },
