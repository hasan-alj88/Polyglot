    { "name": "Data Type", "scope": "entity.name.tag.type.aljam3", "settings": { "foreground": "#FFA500", "fontStyle": "bold" } },
    { "name": "Data Instance", "scope": "entity.name.tag.instance.aljam3", "settings": { "foreground": "#B8860B", "fontStyle": "bold" } },
