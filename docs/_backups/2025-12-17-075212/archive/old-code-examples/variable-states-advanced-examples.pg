# =============================================================================
# Example 1: Complex Error Propagation Through Nested Operations
# Testing: How do errors propagate? Do parent variables inherit child errors?
# =============================================================================

[#] DatabaseResult
[<] .records: pg\array{pg\string} << []
[<] .count: pg\int << 0
[X]

[|] NestedErrorPropagation
[i] .query: pg\string
[t] |T.Call

[W] |W.Python3.11

# First level: Database connection
[r] |connect_to_database
[>] .connection: pg\string >> .db_conn
[>] .errors: pg\array{!} >> .conn_errors
[~]
[~][!] !pg.Database.ConnectionFailed
[~][>] .message: pg\string >> .conn_error_msg
[~][~]# GAP: If connection fails, what happens to .db_conn.state?
[~][~]# Is it Faulted? Does it even exist in scope?
[~][~][o] #None

# Second level: Query execution (depends on first level)
[r] |execute_query
[<] .connection: pg\string << .db_conn        # GAP: What if .db_conn is Faulted?
[<] .sql: pg\string << .query
[>] .result: #DatabaseResult >> .query_result
[>] .errors: pg\array{!} >> .query_errors
[~]
[~][!] !pg.Database.QueryFailed
[~][>] .message: pg\string >> .query_error_msg
[~][~]# GAP: Do .query_errors include .conn_errors from parent?
[~][~]# Or are errors isolated per pipeline call?
[~][~][o] #None

# GAP: Can we check multiple error conditions in sequence?
[?] .db_conn.state =? #Variables.States.Faulted
[~][r] |U.Log.Error
[~][<] .msg: pg\string << "Connection failed: {.conn_error_msg}"
[~][o] #None

[?] .query_result.state =? #Variables.States.Faulted
[~][r] |U.Log.Error
[~][<] .msg: pg\string << "Query failed: {.query_error_msg}"
[~][o] #None

[?] *?
[~][o] .query_result: #DatabaseResult

[X]


# =============================================================================
# Example 2: Cached State Usage Patterns
# Testing: How does Cached state work? When/how do we mark variables as Cached?
# =============================================================================

[|] CachedStateManagement
[i] .user_id: pg\string
[t] |T.Call

[W] |W.Python3.11

# GAP: How do we explicitly request cached execution?
# Is there a cache directive/annotation?
# Or is caching automatic based on some criteria?

# Hypothetical syntax 1: Queue control for caching?
[Q] |Q.Cache.Enable
[<] .ttl: pg\int << 3600                      # GAP: Is this valid syntax?

[r] |fetch_expensive_user_profile
[<] .id: pg\string << .user_id
[>] .profile: pg\string >> .user_profile
[>] .errors: pg\array{!} >> .profile_errors

# GAP: How do we check if result came from cache?
[?] .user_profile.state =? #Variables.States.Cached
[~][r] |U.Log.Info
[~][<] .msg: pg\string << "Using cached profile (age: {.user_profile.cache_age})"
[~]# GAP: Do cached variables have .cache_age field?
[~]# Or other cache metadata?

[?] .user_profile.state =? #Variables.States.Ready
[~][r] |U.Log.Info
[~][<] .msg: pg\string << "Fresh profile fetched"

[?] *?
[~][r] |U.Log.Warn
[~][<] .msg: pg\string << "Unexpected state: {.user_profile.state}"

[o] .user_profile: pg\string
[X]


# =============================================================================
# Example 3: Dirty State and Cache Invalidation
# Testing: How/when does Dirty state occur? How to invalidate cache?
# =============================================================================

[|] CacheInvalidationPattern
[i] .item_id: pg\string
[t] |T.Call

[W] |W.Python3.11

# Fetch with caching enabled
[r] |get_product_details
[<] .id: pg\string << .item_id
[>] .product: pg\string >> .cached_product

# Later... product gets updated elsewhere
[r] |update_product_price
[<] .id: pg\string << .item_id
[<] .new_price: pg\float << 29.99
[>] .success: #Boolean >> .update_result

# GAP: How do we mark .cached_product as Dirty?
# Is there explicit cache invalidation syntax?
# Hypothetical syntax 1: Queue control?
[Q] |Q.Cache.Invalidate
[<] .variable: ??? << .cached_product         # GAP: How to reference variable itself?

# Hypothetical syntax 2: Special marker?
# [V] .cached_product                         # GAP: Variable invalidation marker?

# GAP: After invalidation, what is .cached_product.state?
# Is it Dirty? Does it automatically refetch?
# Or do we need explicit refetch?

[?] .cached_product.state =? #Variables.States.Dirty
[~]# Refetch because cache is dirty
[~][r] |get_product_details
[~][<] .id: pg\string << .item_id
[~][>] .product: pg\string >> .fresh_product
[~][o] .fresh_product: pg\string

[?] *?
[~][o] .cached_product: pg\string

[X]


