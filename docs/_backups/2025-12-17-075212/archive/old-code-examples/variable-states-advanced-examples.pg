[|] StateTransitionTiming
[i] #None
[t] |T.Call

[W] |W.Python3.11

[r] |start_long_operation
[>] .result: pg\string >> .long_op

# GAP: Immediately after [r], what is .long_op.state?
# Is it Pending? Or is it Ready because [r] waits?
[r] |check_state_immediately
[<] .state: pg\string << .long_op.state        # GAP: Can we pass .state itself as value?

# GAP: Between operations, can state change?
# If .long_op was Pending, does it become Ready before next [r]?
[r] |U.Log.Info
[<] .msg: pg\string << "State is now: {.long_op.state}"

# What if we explicitly don't wait?
[p] |start_parallel_operation
[>] .result: pg\string >> .parallel_op

# GAP: Right after [p], .parallel_op should be Pending, right?
# Can we observe this before it becomes Ready?
[r] |check_parallel_state
[<] .state: pg\string << .parallel_op.state
# GAP: Or does even reading .state cause automatic wait?

[o] #None
