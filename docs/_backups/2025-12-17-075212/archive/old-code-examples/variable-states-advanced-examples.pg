# =============================================================================
# Example 8: Complex Join with Mixed States
# Testing: How does Join handle variables in different states?
# =============================================================================

[|] MixedStateJoin
[i] #None
[t] |T.Call

[W] |W.Python3.11

# Launch multiple parallel operations
[p] |fetch_data_source_a
[>] .data: pg\string >> .source_a              # Fast - completes quickly

[p] |fetch_data_source_b
[>] .data: pg\string >> .source_b              # Slow - takes time

[p] |fetch_data_source_c
[>] .data: pg\string >> .source_c              # Unreliable - might fail

# GAP: If we check states before Join, what do we see?
[r] |U.Log.Debug
[<] .msg: pg\string << "A: {.source_a.state}, B: {.source_b.state}, C: {.source_c.state}"

# Join waits for all
[Y] |Y.Join
[<] .source_a
[<] .source_b
[<] .source_c

# GAP: After Join, are variables guaranteed to be Ready OR Faulted?
# Or can they be in other states (Cached, Retrying)?

# Complex state checking
[?] .source_a.state =? #Variables.States.Ready
[~][?] .source_b.state =? #Variables.States.Ready
[~][~][?] .source_c.state =? #Variables.States.Ready
[~][~][~]# All ready - best case
[~][~][~][r] |merge_all_sources
[~][~][~][<] .a: pg\string << .source_a
[~][~][~][<] .b: pg\string << .source_b
[~][~][~][<] .c: pg\string << .source_c
[~][~][~][>] .merged: pg\string >> .result
[~][~][~][o] .result: pg\string
[~][~]
[~][~][?] .source_c.state =? #Variables.States.Faulted
[~][~][~]# C failed but A and B ready
[~][~][~][r] |merge_partial_sources
[~][~][~][<] .a: pg\string << .source_a
[~][~][~][<] .b: pg\string << .source_b
[~][~][~][>] .merged: pg\string >> .partial_result
[~][~][~][o] .partial_result: pg\string

# GAP: This nested state checking is getting complex
# Is there a better pattern for "if all ready" vs "if some ready"?
# Maybe a state aggregation function?

[?] *?
[~][r] |U.Log.Error
[~][<] .msg: pg\string << "Multiple sources failed"
[~][o] #None

[X]


