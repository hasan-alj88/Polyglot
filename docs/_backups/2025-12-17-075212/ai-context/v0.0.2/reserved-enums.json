{
  "polyglot_v0.0.2_reserved_enumerations": {
    "version": "0.0.2",
    "description": "Reserved enumerations provided by Polyglot runtime",
    "namespace_convention": "# prefix required",

    "#PgVar.States": {
      "full_name": "#PgVar.States",
      "description": "Variable state enumeration",
      "context": "Used to check variable states in conditional blocks",
      "fields": {
        "Declared": {
          "value": "#PgVar.States.Declared",
          "description": "Schema only, no value",
          "mvp": true
        },
        "DefaultReady": {
          "value": "#PgVar.States.DefaultReady",
          "description": "Has default, allows one override",
          "mvp": true
        },
        "Pending": {
          "value": "#PgVar.States.Pending",
          "description": "Async operation in progress",
          "mvp": true
        },
        "Ready": {
          "value": "#PgVar.States.Ready",
          "description": "Value available, immutable",
          "mvp": true
        },
        "Faulted": {
          "value": "#PgVar.States.Faulted",
          "description": "Operation failed",
          "mvp": true
        },
        "Retrying": {
          "value": "#PgVar.States.Retrying",
          "description": "Automatic retry in progress",
          "mvp": false,
          "epic": "Epic 2 (Queue Management)"
        },
        "Paused": {
          "value": "#PgVar.States.Paused",
          "description": "Waiting for external trigger",
          "mvp": false,
          "epic": "Epic 2 (Queue Management)"
        },
        "Cached": {
          "value": "#PgVar.States.Cached",
          "description": "Cached result, may be stale",
          "mvp": false,
          "epic": "Epic 3 (Advanced Features)"
        },
        "Dirty": {
          "value": "#PgVar.States.Dirty",
          "description": "Cache invalid, needs refresh",
          "mvp": false,
          "epic": "Epic 3 (Advanced Features)"
        }
      },
      "usage_example": "[?] .variable.pgvar.state =? #PgVar.States.Ready",
      "reserved_namespace": ".*.pgvar.state always resolves to #PgVar.States.*"
    },

    "#Boolean": {
      "full_name": "#Boolean",
      "description": "Boolean enumeration (replaces pg\\bool primitive)",
      "fields": {
        "True": {
          "value": "#Boolean.True",
          "description": "Boolean true value"
        },
        "False": {
          "value": "#Boolean.False",
          "description": "Boolean false value"
        }
      },
      "usage": "pg\\bool type uses #Boolean enumeration",
      "examples": [
        "[<] .enabled: pg\\bool <~ #Boolean.True",
        "[?] .flag =? #Boolean.False"
      ]
    },

    "#None": {
      "full_name": "#None",
      "description": "Unit type (no value)",
      "usage": "Represents absence of value",
      "contexts": [
        "Pipeline output when no value returned",
        "Optional values",
        "Void functions"
      ],
      "examples": [
        "[o] #None",
        "[i] .optional: #UserProfile | #None"
      ],
      "note": "NOT the same as null - #None is an explicit type"
    },

    "#Status": {
      "status": "PROPOSED (not yet approved)",
      "description": "Pipeline execution status",
      "fields_proposed": {
        "Running": "#Status.Running",
        "Completed": "#Status.Completed",
        "Failed": "#Status.Failed",
        "Paused": "#Status.Paused"
      },
      "note": "May be implemented in future versions"
    },

    "naming_conventions": {
      "short_names": {
        "PgVar": "Polyglot Variable (shortened for brevity)",
        "reason": "#Variables.States was too verbose"
      },
      "old_names_deprecated": {
        "#Variables.States": "DEPRECATED - use #PgVar.States",
        "#Bool": "DEPRECATED - use #Boolean"
      }
    },

    "reserved_namespace_fields": {
      ".*.pgvar.*": {
        "description": "Reserved metadata namespace for variables",
        "always_ready": true,
        "database_tracked": true,
        "fields": {
          ".*.pgvar.state": {
            "type": "#PgVar.States.*",
            "description": "Current state of variable",
            "always_ready": true,
            "queryable": true
          },
          ".*.pgvar.errors": {
            "type": "pg\\array{!ErrorType}",
            "description": "Error details if Faulted",
            "only_when": "state = Faulted"
          },
          ".*.pgvar.history.{StateName}.at": {
            "type": "pg\\dt",
            "description": "Timestamp of state transition",
            "example": ".user.pgvar.history.Pending.at"
          }
        }
      }
    },

    "critical_notes": {
      "no_keywords": "Reserved enumerations still require # prefix",
      "correct_usage": "#PgVar.States.Ready",
      "incorrect_usage": [
        "PgVar.States.Ready (missing #)",
        "#Variables.States.Ready (old name)",
        "#pgvar.states.ready (case sensitive)"
      ],
      "case_sensitivity": "Polyglot identifiers are case-sensitive"
    }
  }
}
