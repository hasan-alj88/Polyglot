[@] Local@DataProcessor:1.0.0
[#] 1
[<] @API << Community@WebAPI:2.1.0
[<] @DB << Community@Database:3.0.0
[X]

/*
 * =============================================================================
 * ENUMERATIONS WITH STATE-AWARE FIELDS
 * =============================================================================
 */

[#] ProcessingStatus
[<] .Pending
[<] .Processing
[<] .Completed
[<] .Failed
[X]

[#] APIConfig
[<] .endpoint: pg\string                           // Declared - must provide
[<] .timeout: pg\int <~ 30                          // DefaultReady - default 30s
[<] .max_retries: pg\int <~ 3                       // DefaultReady - default 3
[<] .api_version: pg\string << "v2"                 // Ready - always "v2"
[X]

[#] DataRecord
[<] .id: pg\string                                  // Declared - must provide
[<] .name: pg\string                                // Declared - must provide
[<] .email: pg\string                               // Declared - must provide
[<] .created_at: pg\dt <~ DT"2025-01-01 00:00:00"  // DefaultReady - default date
[<] .status: #ProcessingStatus <~ #ProcessingStatus.Pending  // DefaultReady
[X]

[#] ProcessingResult
[<] .total_records: pg\int <~ 0                     // DefaultReady - default 0
[<] .successful: pg\int <~ 0                        // DefaultReady - default 0
[<] .failed: pg\int <~ 0                            // DefaultReady - default 0
[<] .execution_time: pg\time                        // Declared - calculated later
[X]

/*
 * =============================================================================
 * MAIN PIPELINE: Process User Data from API
 * =============================================================================
 */

[|] ProcessUserDataBatch
[i] .batch_id: pg\string                            // Ready - provided by caller
[i] .config: #APIConfig << #APIConfig               // DefaultReady fields kick in

[t] T.Cron"0 */6 * * *"

[W] |W.Python3.11

// Fetch data from API (async operation)
[r] @API|FetchUserData
[<] .batch_id: pg\string << .batch_id
[<] .endpoint: pg\string << .config.endpoint
[<] .timeout: pg\int << .config.timeout             // Uses default 30 or override
[>] .data: pg\array{#DataRecord} >> .raw_data
[>] .errors: pg\array{!} >> .fetch_errors           // Error field

// Check if fetch succeeded or faulted
[?] .raw_data.state =? #Variables.States.Faulted
[~][r] |U.Log.Error
[~][<] .msg: pg\string << "API fetch failed for batch {.batch_id}"
[~][<] .errors: pg\array{!} << .fetch_errors
[~]
[~][r] @DB|LogFailedBatch
[~][<] .batch_id: pg\string << .batch_id
[~][<] .error_details: pg\array{!} << .fetch_errors
[~]
[~][o] !pg.Network.ConnectionFailed

// Fetch succeeded - process data
[?] .raw_data.state =? #Variables.States.Ready
[~][r] |U.Log.Info
[~][<] .msg: pg\string << "Fetched {String.Length"{.raw_data}"} records"
[~]
[~]// Initialize result tracking
[~][i] .result: #ProcessingResult << #ProcessingResult  // Defaults applied!
[~]
[~]// Process each record in parallel
[~][r] ~ForEach
[~][<] .raw_data
[~][>] .record
[~][~]
[~][~][p] |ValidateAndSaveRecord
[~][~][<] .record: #DataRecord << .record
[~][~][>] .saved: pg\bool >> .save_result
[~][~][>] .errors: pg\array{!} >> .save_errors
[~][~]
[~][~]// Check save result state
[~][~][?] .save_result.state =? #Variables.States.Ready
[~][~][~][?] .save_result =? #True
[~][~][~][~]// Success
[~][~][~][~][o] !NoError
[~][~][~]
[~][~][~][?] *?
[~][~][~][~]// Validation failed but not faulted
[~][~][~][~][r] |U.Log.Warn
[~][~][~][~][<] .msg: pg\string << "Record {.record.id} validation failed"
[~][~][~][~]
[~][~][~][~][o] !NoError
[~][~]
[~][~][?] .save_result.state =? #Variables.States.Faulted
[~][~][~]// Operation faulted
[~][~][~][r] |U.Log.Error
[~][~][~][<] .msg: pg\string << "Failed to save record {.record.id}"
[~][~][~][<] .errors: pg\array{!} << .save_errors
[~][~][~]
[~][~][~][o] @DB!Database.ConnectionFailed
[~][~]
[~][~][?] *?
[~][~][~]// Catchall
[~][~][~][o] !NoError
[~]
[~]// Generate summary report
[~][r] @DB|GetProcessingStats
[~][<] .batch_id: pg\string << .batch_id
[~][>] .stats: #ProcessingResult >> .final_result
[~][>] .errors: pg\array{!} >> .stats_errors
[~]
[~][?] .final_result.state =? #Variables.States.Ready
[~][~][r] |U.Log.Info
[~][~][<] .msg: pg\string << "Batch {.batch_id} complete: {.final_result.successful} success, {.final_result.failed} failed"
[~][~]
[~][~][o] !NoError
[~]
[~][?] *?
[~][~][r] |U.Log.Error
[~][~][<] .msg: pg\string << "Failed to get stats for batch {.batch_id}"
[~][~][<] .errors: pg\array{!} << .stats_errors
[~][~]
[~][~][o] @DB!Database.QueryFailed

// Catchall for unexpected states
[?] *?
[~][r] |U.Log.Error
[~][<] .msg: pg\string << "Unexpected state in ProcessUserDataBatch"
[~]
[~][o] !pg.System.UnexpectedError

[o] #None
[X]

/*
 * =============================================================================
 * HELPER PIPELINE: Validate and Save Single Record
 * =============================================================================
 */

[|] ValidateAndSaveRecord
[i] .record: #DataRecord                            // Ready - must have value

[t] |T.Call

[W] |W.Python3.11

// Validate email format
[r] |validate_email
[<] .email: pg\string << .record.email
[>] .valid: pg\bool >> .email_valid
[>] .errors: pg\array{!} >> .validation_errors

[?] .email_valid.state =? #Variables.States.Faulted
[~][r] |U.Log.Warn
[~][<] .msg: pg\string << "Email validation failed for {.record.id}"
[~]
[~][o] #False

[?] .email_valid =? #True
[~]// Email valid - save to database
[~][r] @DB|SaveRecord
[~][<] .record: #DataRecord << .record
[~][>] .success: pg\bool >> .save_success
[~][>] .errors: pg\array{!} >> .db_errors
[~]
[~][?] .save_success.state =? #Variables.States.Ready
[~][~][o] .save_success
[~]
[~][?] *?
[~][~]// Faulted or other state
[~][~][o] #False

[?] *?
[~]// Email invalid
[~][o] #False

[X]

/*
 * =============================================================================
 * CONFIGURATION OVERRIDE EXAMPLE
 * =============================================================================
 */

[|] ProcessUrgentBatch
[i] .batch_id: pg\string

[t] |T.Call

[W] |W.Python3.11

/*
 * Create config with custom timeout (override default)
 * .config.timeout is DefaultReady with 30
 * .config.max_retries is DefaultReady with 3
 */
[i] .config: #APIConfig << #APIConfig

// Override timeout for urgent processing (first override -> becomes Ready)
[r] .urgent_config.timeout: pg\int << 5             // Override to 5 seconds
[r] .urgent_config.max_retries: pg\int << 10        // Override to 10 retries
// Now .urgent_config.timeout is Ready (immutable)
// Cannot override again!

[r] |ProcessUserDataBatch
[<] .batch_id: pg\string << .batch_id
[<] .config: #APIConfig << .urgent_config

[o] #None
[X]
